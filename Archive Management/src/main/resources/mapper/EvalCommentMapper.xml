<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.archivemanagement.mapper.EvalCommentMapper">

    <!-- 查询某学生的所有评语 -->
    <select id="selectByStudentId" resultType="com.example.archivemanagement.entity.EvalComment">
        SELECT * FROM eval_comment
        WHERE student_id = #{studentId}
        ORDER BY create_time DESC
    </select>

    <!-- 查询某导师对某学生的评语 -->
    <select id="selectByTutorAndStudent" resultType="com.example.archivemanagement.entity.EvalComment">
        SELECT * FROM eval_comment
        WHERE tutor_id = #{tutorId}
          AND student_id = #{studentId}
        ORDER BY create_time DESC
    </select>

</mapper>
